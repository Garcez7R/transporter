{
  "name": "transporter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc -b --pretty false",
    "cf:login": "npx wrangler login",
    "cf:d1:create": "npx wrangler d1 create transporter",
    "cf:d1:apply": "npx wrangler d1 migrations apply transporter",
    "cf:dev": "npm run build && npx wrangler pages dev dist",
    "cf:deploy": "npm run build && npx wrangler pages deploy dist --project-name transporter"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250813.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.2"
  }
}
